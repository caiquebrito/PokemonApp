<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icons crop to a safe-zone circle (~66dp of the 108dp canvas), so inset the
     Pokéball so it stays fully visible regardless of the launcher's mask shape. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/pokeball"
    android:insetLeft="17%"
    android:insetRight="17%"
    android:insetTop="17%"
    android:insetBottom="17%" />
