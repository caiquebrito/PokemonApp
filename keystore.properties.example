# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored — never commit it.
#
# For CI (Bitrise), set the equivalent environment variables instead:
#   KEYSTORE_PATH      → absolute path where the .jks lands on the build machine
#   KEYSTORE_PASSWORD  → store password
#   KEY_ALIAS          → key alias (pokemon)
#   KEY_PASSWORD       → key password
#
# Generate a keystore (run as one line):
#   keytool -genkey -v -keystore tools/signin/release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias pokemon -storepass YOUR_STORE_PASSWORD -keypass YOUR_KEY_PASSWORD -dname "CN=Your Name, O=Your Org, C=BR"

storeFile=tools/signin/release.jks
storePassword=your_store_password
keyAlias=pokemon
keyPassword=your_key_password
