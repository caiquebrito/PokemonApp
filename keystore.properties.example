# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored — never commit it.
#
# For CI (Bitrise), set the equivalent environment variables:
#   KEYSTORE_PATH, KEYSTORE_PASSWORD, KEY_ALIAS, KEY_PASSWORD
#
# Generate a keystore with:
#   keytool -genkey -v -keystore release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias pokemon

storeFile=release.jks
storePassword=your_store_password
keyAlias=pokemon
keyPassword=your_key_password
